#!/usr/bin/env bash
# UCommon pre-commit hook: build + test via cmake check target
# Located in .more-hooks/hooks/pre-commit, registered via more-hooks framework

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_DIR="$REPO_ROOT/build"

if [ ! -d "$BUILD_DIR" ]; then
    echo "[pre-commit] build/ not found, skipping build+test check"
    exit 0
fi

echo "[pre-commit] Building and running tests..."
if ! cmake --build "$BUILD_DIR" --config Release --target UCommon_check 2>&1; then
    echo "[pre-commit] Build or tests failed. Commit aborted."
    exit 1
fi

echo "[pre-commit] Build and tests passed."

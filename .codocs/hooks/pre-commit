#!/usr/bin/env bash
# codocs pre-commit hook (auto-installed by codocs init)
# Phase 1: codocs lint — ORPHAN/MISSING 检查，有问题直接拦截
# Phase 2: 检测受管控的代码文件改动时，若无对应 .codocs/ 文档改动，设标记（不拦截）
# Phase 3: 检测已暂存的 .codocs/ MD 改动，若其父目录 MD 未同步更新，设标记（不拦截）

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
CODOCS_CONFIG="$ROOT/.codocs/config.json"

# 没有 .codocs/config.json 则跳过
if [ ! -f "$CODOCS_CONFIG" ]; then
  exit 0
fi

PYTHON=$(command -v python 2>/dev/null || command -v python3 2>/dev/null)
if [ -z "$PYTHON" ]; then
  echo "[codocs] ERROR: python not found, cannot check doc coverage" >&2
  echo "         Install Python or run with --no-verify to bypass." >&2
  exit 1
fi
# Verify the python binary actually works (Windows Store stub may be a no-op)
if ! "$PYTHON" -c "import sys" 2>/dev/null; then
  echo "[codocs] ERROR: python found at $PYTHON but cannot execute" >&2
  exit 1
fi

# ── Phase enable helper ───────────────────────────────────────────────────
hook_enabled() {
  local name="$1"
  "$PYTHON" - "$CODOCS_CONFIG" "$name" << 'PYEOF'
import json, sys
cfg_path, name = sys.argv[1], sys.argv[2]
try:
    d = json.load(open(cfg_path, encoding="utf-8"))
    print("1" if d.get("hooks", {}).get(name, True) else "0")
except Exception:
    print("1")
PYEOF
}

DEPS_FLAG="${TMPDIR:-/tmp}/codocs_needs_dep_check"
DEPS_FILE="${TMPDIR:-/tmp}/codocs_missing_deps"

# ── Shared variables (needed by multiple phases) ──────────────────────────
INIT_PY="$ROOT/.codocs/scripts/codocs.py"

# 获取暂存文件列表（Phase 2/3/4 均需要）
staged_files=$(git diff --cached --name-only --diff-filter=ACMRT)

if [ -z "$staged_files" ]; then
  exit 0
fi

# ── Phase 1: codocs lint（ORPHAN / MISSING 检查） ──────────────────────────
if [ "$(hook_enabled lint)" = "1" ]; then

if [ -f "$INIT_PY" ]; then
  set +e  # lint 非零退出时不要触发 errexit
  lint_output=$("$PYTHON" "$INIT_PY" "$ROOT" --lint 2>/dev/null)
  lint_rc=$?
  set -e

  if [ $lint_rc -ne 0 ]; then
    echo ""
    echo "[codocs] lint: 发现文档质量问题，提交已拦截"
    echo ""
    echo "$lint_output"
    echo ""
    echo "请修复以上问题后重新提交，或使用 git commit --no-verify 跳过"
    exit 1
  fi
fi
fi

# ── Phase 2: doc-change 检查 ─────────────────────────────────────────────
if [ "$(hook_enabled doc_change)" = "1" ]; then
# 从 .codocs/config.json 读取 roots（tr -d '\r' 处理 Windows CRLF）
mapfile -t roots < <("$PYTHON" -c "
import json
d = json.load(open('$CODOCS_CONFIG'))
for r in d.get('roots', []):
    print(r)
" 2>/dev/null | tr -d '\r')

if [ ${#roots[@]} -eq 0 ]; then
  exit 0
fi

# staged_files already defined above

# 找出受管控的代码文件（在任意 root 下，排除 .css）
managed_code_files=()
while IFS= read -r f; do
  for root in "${roots[@]}"; do
    if [[ "$f" == ${root}/* ]] && [[ "$f" != *.css ]]; then
      managed_code_files+=("$f")
      break
    fi
  done
done <<< "$staged_files"

# 检查是否有 .codocs/ 文档改动
has_doc_change=false
while IFS= read -r f; do
  if [[ "$f" == .codocs/* ]] && [[ "$f" != .codocs/config.json ]]; then
    has_doc_change=true
    break
  fi
done <<< "$staged_files"

if [ ${#managed_code_files[@]} -gt 0 ] && [ "$has_doc_change" = false ]; then
  # 写入受管控文件列表，供 commit-msg hook 读取
  printf "%s\n" "${managed_code_files[@]}" > "${TMPDIR:-/tmp}/codocs_pending_files"
  touch "${TMPDIR:-/tmp}/codocs_needs_doc_check"

  echo "[codocs] 检测到受管控文件改动，但未找到文档更新"
  echo ""
  echo "以下文件在 codocs 管控范围内："
  for f in "${managed_code_files[@]}"; do
    echo "  • $f  →  .codocs/$f.md"
  done
  echo ""
  echo "选项 A（推荐）：同时 git add 对应的 .codocs/ 文档改动"
  echo "选项 B（跳过）：须先检查对应 md 内容是否因本次改动而过时，确认无需更新后再跳过"
  echo "  步骤 1：逐一打开下列 md，确认其描述仍与代码一致"
  for f in "${managed_code_files[@]}"; do
    echo "           .codocs/$f.md"
  done
  echo "  步骤 2：若确认无需更新，在 commit message 末尾加："
  echo "           ## codocs-skip"
  for f in "${managed_code_files[@]}"; do
    echo "           - .codocs/$f.md: <理由>"
  done
  echo "选项 C：git commit --no-verify（不推荐）"
  echo ""
elif [ "$has_doc_change" = true ]; then
  # 有文档改动，清除 Phase 2 标记
  rm -f "${TMPDIR:-/tmp}/codocs_pending_files" "${TMPDIR:-/tmp}/codocs_needs_doc_check"
fi
fi

# ── Phase 3: 父目录 MD 同步检查 ─────────────────────────────────────────
if [ "$(hook_enabled parent_sync)" = "1" ]; then
# 找出已暂存的 .codocs/*.md 文件（排除 _notes/ 和 scripts/）
staged_doc_files=()
while IFS= read -r f; do
  if [[ "$f" =~ ^\.codocs/.*\.md$ ]] && \
     [[ "$f" != .codocs/_notes/* ]] && \
     [[ "$f" != .codocs/scripts/* ]]; then
    staged_doc_files+=("$f")
  fi
done <<< "$staged_files"

if [ ${#staged_doc_files[@]} -gt 0 ] && [ -f "$INIT_PY" ]; then
  set +e
  missing_parents=$("$PYTHON" "$INIT_PY" "$ROOT" --parent-sync "${staged_doc_files[@]}" 2>/dev/null)
  parent_rc=$?
  set -e

  if [ $parent_rc -ne 0 ] && [ -n "$missing_parents" ]; then
    echo "$missing_parents" > "${TMPDIR:-/tmp}/codocs_missing_parents"
    touch "${TMPDIR:-/tmp}/codocs_needs_parent_sync"

    echo ""
    echo "[codocs] 部分父目录 MD 未同步更新"
    echo ""
    echo "以下父目录 MD 未包含在本次提交中："
    while IFS= read -r p; do echo "  • $p"; done <<< "$missing_parents"
    echo ""
    echo "选项 A（推荐）：git add 对应的父目录 MD"
    echo "选项 B：逐一声明跳过（在 commit message 末尾加）："
    echo "         ## codocs-skip"
    echo "         - .codocs/src.md: <理由>"
    echo "选项 C：全局跳过："
    echo "         ## codocs-skip"
    echo "         - [all]: <理由>"
    echo ""
  else
    # 父目录全部已同步，清除旧标记
    rm -f "${TMPDIR:-/tmp}/codocs_missing_parents" "${TMPDIR:-/tmp}/codocs_needs_parent_sync"
  fi
fi
fi

# ── Phase 4: dependency check ─────────────────────────────────────────────
if [ "$(hook_enabled dependencies)" = "1" ] && [ -f "$INIT_PY" ]; then
  # Remove stale files from any previous interrupted commit
  rm -f "$DEPS_FLAG" "$DEPS_FILE"

  # Build staged files array for --check-deps (reuse staged_files from above)
  mapfile -t staged_all < <(echo "$staged_files")

  set +e
  missing_deps=$("$PYTHON" "$INIT_PY" "$ROOT" --check-deps "${staged_all[@]}" 2>/dev/null)
  deps_rc=$?
  set -e

  if [ $deps_rc -ne 0 ] && [ -n "$missing_deps" ]; then
    echo "$missing_deps" > "$DEPS_FILE"
    touch "$DEPS_FLAG"

    echo ""
    echo "[codocs] 依赖规则触发，但关联文档未更新"
    echo ""

    "$PYTHON" - "$CODOCS_CONFIG" "${staged_all[@]}" << 'PYEOF'
import json, sys
cfg, *staged = sys.argv[1], sys.argv[2:]
staged_set = {p.lstrip("./").replace("\\", "/") for p in staged}
try:
    deps = json.load(open(cfg, encoding="utf-8")).get("dependencies", [])
except Exception:
    deps = []
for rule in deps:
    if not isinstance(rule, dict): continue
    when = rule.get("when", [])
    update = rule.get("update", [])
    if not isinstance(when, list) or not isinstance(update, list): continue
    triggers = [w for w in when if isinstance(w, str) and w.lstrip("./").replace("\\","/") in staged_set]
    if triggers:
        for t in triggers:
            print(f"  触发文件: {t}")
        for u in update:
            if isinstance(u, str) and u.lstrip("./").replace("\\","/") not in staged_set:
                print(f"    → 需更新: {u}")
PYEOF

    echo ""
    echo "选项 A（推荐）：git add 对应的 .codocs/ 文档改动"
    echo "选项 B：在 commit message 末尾加跳过标记："
    echo "         ## codocs-skip"
    echo "         - .codocs/src/Foo.cpp.md: <理由>"
    echo "选项 C：git commit --no-verify（不推荐）"
    echo ""
  fi
fi

exit 0
